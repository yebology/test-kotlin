# ============================================================
# E2E Orchestrator — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# --- AI Model (for Generate step only) ---

# OpenAI API Key (GPT-3.5 Turbo, GPT-4o Mini)
OPENAI_API_KEY=

# OpenAI API Base URL (optional — default: https://api.openai.com/v1)
# Use this for: Azure OpenAI, self-hosted, proxy, LiteLLM, etc.
#   Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   Local/proxy:  http://localhost:8080/v1
#   LiteLLM:      http://localhost:4000/v1
OPENAI_BASE_URL=

# --- Source Code Repository (optional) ---
# If set, wizard auto-clones this repo before generating test scripts.

# Repo HTTPS URL
REPO_URL=
# Auth token — format depends on provider:
#   CodeCommit: username:password (HTTPS Git credentials from IAM)
#   GitHub: ghp_xxxx (personal access token)
#   GitLab: glpat-xxxx (project access token)
#   Bitbucket: email:api_token (create API token at Personal Settings → API tokens)
#     Format: your.email@company.com:ATBBxxxx...
#     Clone: https://email:token@bitbucket.org/workspace/repo.git
REPO_TOKEN=
# Branch to clone (optional, defaults to repo's default branch)
REPO_BRANCH=

# --- Android SDK ---
ANDROID_HOME=/Users/yobel/Library/Android/sdk
