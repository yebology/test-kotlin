# ============================================================
# E2E Orchestrator — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# --- Kiro CLI (for Generate step) ---
# Login first: kiro-cli login --license free
# No API key needed after login — auth is browser-based.
# For headless/CI: set KIRO_API_KEY (generate at kiro.dev dashboard)
KIRO_API_KEY=

# --- Android SDK ---
ANDROID_HOME=/Users/yobel/Library/Android/sdk
